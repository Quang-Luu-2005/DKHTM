# Only keep LaTeX sources and compiled PDFs in git.
*
!*/
!*.tex
!*.pdf
!slide/images/
!slide/images/*.png
!slide/images/*.jpg
!slide/images/*.jpeg
!slide/images/*.webp
!.gitignore

# 4. Code exceptions: Keep everything in "Cam test" EXCEPT the build folder
!"Cam test"/
!"Cam test"/**

# Re-ignore the PlatformIO build output inside "Cam test"
"Cam test"/build/

#ignore Vscode
.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
