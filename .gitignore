# =========================================================================
# 1. Ignore ALL LaTeX temporary build/auxiliary files everywhere
# =========================================================================
*.aux
*.log
*.toc
*.out
*.fdb_latexmk
*.fls
*.synctex.gz
*.bbl
*.blg
*.nav
*.snm
*.vrb

# =========================================================================
# 2. PlatformIO Build Targets (Ignore only code compilation artifacts)
# =========================================================================
source/.pio/
source/build/

# =========================================================================
# 3. VS Code Configuration & PlatformIO Local Files
# =========================================================================
# Fixes the missing dot (.) in .vscode
source/.vscode/.browse.c_cpp.db*
source/.vscode/c_cpp_properties.json
source/.vscode/launch.json
source/.vscode/ipch/

# Tip: If you want to ignore ALL personal VS Code settings files
# but keep recommended tasks, you can just ignore the whole folder
# or specific files like settings.json:
# source/.vscode/settings.json

# =========================================================================
# 4. Local firmware secrets
# =========================================================================
source/include/config/secrets.h